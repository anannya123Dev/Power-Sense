rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Every document under users/{uid}/... is only readable/writable
    // by the signed-in user that owns that uid. Nobody can read or
    // write another user's devices, settings, or prediction history.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
